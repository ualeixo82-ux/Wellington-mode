-- ============ FUNÇÕES DO AIMBOT (MOBILE) ============
local function getClosestPlayerToCenter()
    local viewportSize = Camera.ViewportSize
    local centerX = viewportSize.X / 2
    local centerY = viewportSize.Y / 2
    local closestPlayer = nil
    local shortestDistance = aimFOV
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            
            if humanoid and humanoid.Health > 0 then
                if teamCheck and player.Team == LocalPlayer.Team then
                    continue
                end
                
                local targetPart = character:FindFirstChild(aimbotPart)
                if aimbotPart == "Random" then
                    local parts = {"Head", "UpperTorso", "LowerTorso", "LeftArm", "RightArm", "LeftLeg", "RightLeg"}
                    targetPart = character:FindFirstChild(parts[math.random(#parts)])
                end
                
                if not targetPart then
                    targetPart = character:FindFirstChild("Head")
                end
                
                if targetPart then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    
                    if onScreen then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(centerX, centerY)).Magnitude
                        
                        if distance < shortestDistance then
                            if wallCheck then
                                local raycastParams = RaycastParams.new()
                                raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
                                raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                                
                                local direction = (targetPart.Position - Camera.CFrame.Position).Unit
                                local rayResult = workspace:Raycast(Camera.CFrame.Position, direction * 1000, raycastParams)
                                
                                if rayResult and rayResult.Instance:IsDescendantOf(character) then
                                    shortestDistance = distance
                                    closestPlayer = targetPart
                                end
                            else
                                shortestDistance = distance
                                closestPlayer = targetPart
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

-- ============ FUNÇÕES ESP ============
local function createESPForPlayer(player)
    if espDrawings[player.Name] then
        clearESPForPlayer(player)
    end
    
    local drawings = {}
    
    -- Criar Box (retângulo)
    if espBoxEnabled then
        local boxOutline = Drawing.new("Square")
        boxOutline.Visible = false
        boxOutline.Color = Color3.fromRGB(255, 255, 255)
        boxOutline.Thickness = 2
        boxOutline.Transparency = 1
        boxOutline.Filled = false
        drawings.boxOutline = boxOutline
        
        local boxFill = Drawing.new("Square")
        boxFill.Visible = false
        boxFill.Color = Color3.fromRGB(255, 255, 255)
        boxFill.Thickness = 1
        boxFill.Transparency = 0.8
        boxFill.Filled = true
        drawings.boxFill = boxFill
    end
    
    -- Criar Linha
    if espLineEnabled then
        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = Color3.fromRGB(255, 255, 255)
        line.Thickness = 1
        line.Transparency = 0.7
        drawings.line = line
    end
    
    -- Criar Nome
    if espNameEnabled then
        local name = Drawing.new("Text")
        name.Visible = false
        name.Color = Color3.fromRGB(255, 255, 255)
        name.Size = 16
        name.Center = true
        name.Outline = true
        name.OutlineColor = Color3.fromRGB(0, 0, 0)
        drawings.name = name
    end
    
    -- Criar Distância
    if espDistanceEnabled then
        local distance = Drawing.new("Text")
        distance.Visible = false
        distance.Color = Color3.fromRGB(255, 200, 0)
        distance.Size = 14
        distance.Center = true
        distance.Outline = true
        distance.OutlineColor = Color3.fromRGB(0, 0, 0)
        drawings.distance = distance
    end
    
    espDrawings[player.Name] = drawings
end

local function clearESPForPlayer(player)
    if espDrawings[player.Name] then
        for _, drawing in pairs(espDrawings[player.Name]) do
            drawing:Remove()
        end
        espDrawings[player.Name] = nil
    end
end

local function clearAllESP()
    for playerName, _ in pairs(espDrawings) do
        local player = Players:FindFirstChild(playerName)
        if player then
            clearESPForPlayer(player)
        end
    end
    espDrawings = {}
end

